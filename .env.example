# WoolesBot - Environment Configuration
# 1. Copy: cp .env.example .env
# 2. Fill in your values below

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get token from @BotFather, chat ID from getUpdates or @userinfobot
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# ── Scraper tuning (optional; see chef_os.py) ─────────────────────────────────
# Woolworths: sequential curl_cffi with human-like pacing (1.5-4s jitter, batch pauses).
# Coles: Chrome only (Imperva JS challenge blocks curl_cffi).
# WOOLIESBOT_CFFI_HTTP_RETRIES=4
# WOOLIESBOT_CHROME_FALLBACK_THRESHOLD=0.60
# WOOLIESBOT_OUTLIER_DEVIATION_PCT=40
# WOOLIESBOT_ADAPTIVE=1
# WOOLIESBOT_METRICS_HISTORY=30
#
# Pacing — jitter between each request (seconds)
# WOOLIESBOT_REQUEST_JITTER_MIN_SEC=1.5
# WOOLIESBOT_REQUEST_JITTER_MAX_SEC=4.0
#
# Batching — pause between groups of N items + session rotation
# WOOLIESBOT_BATCH_SIZE=20
# WOOLIESBOT_BATCH_PAUSE_MIN_SEC=20
# WOOLIESBOT_BATCH_PAUSE_MAX_SEC=40
#
# Circuit breaker — pause + new session after N consecutive failures
# WOOLIESBOT_CIRCUIT_BREAKER_STREAK=3
# WOOLIESBOT_CIRCUIT_BREAKER_PAUSE_SEC=120
#
# Homepage / PDP HTML length floors (Akamai shells vary; raise if you see false positives)
# WOOLIESBOT_WOOLIES_WARMUP_MIN_CHARS=3500
# WOOLIESBOT_PDP_MIN_HTML_CHARS=4500
#
# Optional proxies (residential proxy recommended if blocks persist)
# WOOLIESBOT_HTTP_PROXY=http://user:pass@host:port
# WOOLIESBOT_WOOLIES_PROXY=http://user:pass@host:port
#
# Coles discovery tuning
# WOOLIESBOT_COLES_DISCOVERY_SLEEP_SEC=2
# WOOLIESBOT_COLES_DISCOVERY_MIN_SCORE=0.06

# ── Google Keep Sync ──────────────────────────────────────────────────────────
# Open Google Keep on desktop, navigate to your shopping list note,
# copy the full URL from the address bar (looks like:
#   https://keep.google.com/u/0/#LIST/1GgwxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxZ)
GOOGLE_KEEP_URL=https://keep.google.com/u/0/#LIST/your_list_id_here
