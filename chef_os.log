eventName,eventDetail) {\n  var state = window.colDataUtils.vlc.state;\n  var messageData = {};\n  if (eventDetail && eventDetail.message && eventDetail.message.data) { messageData = eventDetail.message.data }\n  var messageEvent = \"\";\n  if (eventDetail && eventDetail.message && eventDetail.message.event) { messageEvent = eventDetail.message.event }\n  switch (eventName) {\n    case \"auth\":\n      if (window.colDataUtils.vlc.getStatus() && !state.complete) {\n        _satellite.logger.log('vlc: auth fired direct call rule');\n        window.clearTimeout(window.colDataUtils.vlc.timer);\n        window.colDataUtils.vlc.state.complete = true;\n        _satellite.track('view_loaded_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n      }\n      break;\n    case \"customer\":\n      if (window.colDataUtils.vlc.getStatus() && !state.complete) {\n        _satellite.logger.log('vlc: customer fired direct call rule');\n        window.clearTimeout(window.colDataUtils.vlc.timer);\n        window.colDataUtils.vlc.state.complete = true;\n        _satellite.track('view_loaded_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n      }\n      break;\n    case \"customerAttributes\":\n      if (window.colDataUtils.vlc.getStatus() && !state.complete) {\n        _satellite.logger.log('vlc: customerAttributes fired direct call rule');\n        window.clearTimeout(window.colDataUtils.vlc.timer);\n        window.colDataUtils.vlc.state.complete = true;\n        _satellite.track('view_loaded_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n      }\n      break;\n    case \"trolley\":\n      if (window.colDataUtils.vlc.getStatus() && !state.complete) {\n        _satellite.logger.log('vlc: trolley fired direct call rule');\n        window.clearTimeout(window.colDataUtils.vlc.timer);\n        window.colDataUtils.vlc.state.complete = true;\n        _satellite.track('view_loaded_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n      }\n      break;\n    case \"subscription\":\n      if (window.colDataUtils.vlc.getStatus() && !state.complete) {\n        _satellite.logger.log('vlc: subscription fired direct call rule');\n        window.clearTimeout(window.colDataUtils.vlc.timer);\n        window.colDataUtils.vlc.state.complete = true;\n        _satellite.track('view_loaded_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n      }\n      break;\n    case \"setTimer\":\n      if (window.colDataUtils.vlc.timer) {window.clearTimeout(window.colDataUtils.vlc.timer);}\n      window.colDataUtils.vlc.timer = window.setTimeout(function() {\n        _satellite.logger.log('vlc: the timer has expired');\n        window.colDataUtils.vlc.state.timer = true;\n        window.colDataUtils.vlc.event('vlc',eventDetail?eventDetail:{});\n      }, 5000);\n      break;\n    case \"vlc\":\n      _satellite.logger.log('vlc: vlc fired direct call rule');\n      window.colDataUtils.vlc.state.complete = true;\n      switch (messageEvent) {\n        case \"view_loaded\":\n          _satellite.track('view_loaded_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n          break;\n        case \"view_active_orders\":\n          _satellite.track('view_active_orders_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n          break;\n        case \"view_past_orders\":\n          _satellite.track('view_past_orders_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n          break;\n        case \"view_business_orders\":\n          _satellite.track('view_business_orders_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n          break;\n        case \"view_approval_requests\":\n          _satellite.track('view_approval_requests_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n          break;\n        case \"view_order\":\n          _satellite.track('view_order_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n          break;\n        case \"store_locator_store_search\":\n          _satellite.track('store_locator_store_search_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n          break;\n        case \"store_locator_store_details\":\n          _satellite.track('store_locator_store_details_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n          break;\n        case \"catalogue_loaded\":\n          _satellite.track('catalogue_loaded_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n          break;\n        default:\n          _satellite.track('view_loaded_complete',{\"state\":state,\"message\":{\"data\":messageData}});\n      }\n      break;\n    default:\n      return;\n  }\n}\n\n/* tdp */\nwindow.colDataUtils.tdp = {\n  \"tiles\": [],\n  \"path\": \"\",\n  \"orderProducts\": [],\n  \"clickState\": {}\n}\nwindow.colDataUtils.tdp.storeTiles = function(tiles, details) {\n  var newTiles = tiles;\n  if (details) {\n    newTiles = tiles.map(function(tile) {\n      return Object.assign({}, tile, details)\n    });\n  }\n  if (colDataUtils.tdp.tiles.length == 0) {\n    colDataUtils.tdp.tiles = newTiles;\n    colDataUtils.tdp.path = window.location.pathname;\n  } else {\n    if (colDataUtils.tdp.path == window.location.pathname) {\n      colDataUtils.tdp.tiles = colDataUtils.tdp.tiles.concat(newTiles);\n    } else {\n      colDataUtils.tdp.tiles = newTiles;\n      colDataUtils.tdp.path = window.location.pathname;\n    }\n  }\n}\nwindow.colDataUtils.tdp.getProductDetails = function(sku, tiles_on_page) {\n  var products = tiles_on_page.filter(function(tile) {\n    return tile.id == sku;\n  });\n  if (products.length > 1 && document.querySelectorAll('.promo-product-tile').length > 0) {\n    return products[products.length - 1];\n  } else {\n    return products[0];\n  }\n}\nwindow.colDataUtils.tdp.storeOrderProducts = function(tiles) {\n  var newTiles = tiles;\n  colDataUtils.tdp.orderProducts = newTiles;\n}\nwindow.colDataUtils.tdp.getOrderProductDetails = function(sku, tiles_on_page) {\n  var products = tiles_on_page.filter(function(tile) {\n    return tile.productId == sku;\n  });\n  if (products.length > 0) {\n    return products[products.length - 1];\n  }\n}\n\n/* btd */\nwindow.colDataUtils.btd = {\n  \"pids\": [],\n  \"productString\": []\n}\nwindow.colDataUtils.btd.processTiles = function() {\n  var pids = window.colDataUtils.btd.pids.join(',');\n  var productString = window.colDataUtils.btd.productString.join(',');\n  window.colDataUtils.btd.pids = [];\n  window.colDataUtils.btd.productString = [];\n  _satellite.track('batch_tiles_display',{\"pids\":pids,\"productString\":productString});\n}\nwindow.colDataUtils.btd.batchTiles = function(tiles, details, pids, productString) {\n  if (window.colDataUtils.btd.timer) { clearTimeout(window.colDataUtils.btd.timer); }\n  if (pids) { window.colDataUtils.btd.pids.push(pids); }\n  if (productString) {\n    var productStringSplit = productString.split(',');\n    for (var i = 0; i \u003C productStringSplit.length; i++) {\n      if (window.colDataUtils.btd.productString.indexOf(productStringSplit[i]) == -1) {\n        window.colDataUtils.btd.productString.push(productStringSplit[i]);\n      }\n    }\n  }\n  window.colDataUtils.btd.timer = setTimeout(window.colDataUtils.btd.processTiles,2000);\n}\nwindow.colDataUtils.btd.clearTiles = function() {\n  if (window.colDataUtils.btd.timer) { clearTimeout(window.colDataUtils.btd.timer); }\n  window.colDataUtils.btd.pids = [];\n  window.colDataUtils.btd.productString = [];\n}\n\n/* alr */\nwindow.colDataUtils.alr = {\n  \"flag\": false,\n  \"id\": \"\",\n  \"state\": \"unknown\"\n}\nif (typeof Storage != \"undefined\") {\n  window.colDataUtils.alr.setState = function(isAuth) {\n    var oldState = window.localStorage.getItem('colData:alr:state');\n    var newState = isAuth ? \"A\" : \"U\";\n    if (!oldState || oldState == \"A\") {\n      window.localStorage.setItem('colData:alr:state', newState);\n      r