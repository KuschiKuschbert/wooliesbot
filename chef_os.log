and-reviews-container[_ngcontent-serverApp-c599969429]{position:relative;width:100%;max-width:1456px;margin:0 auto;padding:0 1.25rem}.ratings-and-reviews-container.hidden[_ngcontent-serverApp-c599969429]{display:none}@media (min-width: 48rem){.ratings-and-reviews-container[_ngcontent-serverApp-c599969429]{margin:0;padding:0 2rem}}@media (min-width: 80rem){.ratings-and-reviews-container[_ngcontent-serverApp-c599969429]{margin:0 auto;width:73rem;padding:0}}@media (min-width: 90rem){.ratings-and-reviews-container[_ngcontent-serverApp-c599969429]{width:82rem}}@media (min-width: 105rem){.ratings-and-reviews-container[_ngcontent-serverApp-c599969429]{width:91rem}}\u003C/style>\u003Cstyle id=\"global-sku-styles\">\n    /* Varieties & Alternative Button Styling (Standard DOM) */\n    .custom-view-details-btn-standard {\n        --background: var(--color-action-background-primary-default);\n        --text-color: var(--color-action-text-primary-default);\n        background-color: var(--background) !important;\n        color: var(--text-color) !important;\n        width: 100% !important;\n        height: 40px !important;\n        padding: 0 !important;\n        font-size: 14px !important;\n        border-radius: 36px !important;\n        border: none !important;\n        cursor: pointer !important;\n        display: inline-flex !important;\n        align-items: center !important;\n        justify-content: center !important;\n        font-family: inherit !important;\n        font-weight: 600 !important;\n        text-decoration: none !important;\n        box-sizing: border-box !important;\n        margin-top: 10px !important;\n    }\n\n    .custom-view-details-btn-standard:hover, \n    .custom-view-details-btn-standard:focus {\n        --background: var(--color-action-background-primary-focus);\n        --text-color: var(--color-action-text-primary-focus);\n        background-color: var(--background) !important;\n        color: var(--text-color) !important;\n    }\n\u003C/style>\u003Cscript>\n(function () {\n    'use strict';\n\n    const CONFIG = {\n        skuEndpoint: 'https://cdn0.woolworths.media/wowssr/assets/tga-sku.json',\n        buttonLabel: 'View Details',\n        targetSkus: [],\n        isInitialized: false,\n        tracking: {\n            enabled: true,\n            category: 'SKU Replacement',\n            action: 'View Details Click',\n            labelPrefix: 'SKU: '\n        }\n    };\n\n    function triggerTracking(sku) {\n        if (!CONFIG.tracking.enabled) return;\n        if (typeof (utag) !== 'undefined') { \n            utag.link({ \n                'event.Category': CONFIG.tracking.category, \n                'event.Action': CONFIG.tracking.action, \n                'event.Label': CONFIG.tracking.labelPrefix + sku \n            });\n        }\n    }\n\n    const SHADOW_CSS = `\n        .custom-view-details-btn {\n            --background: var(--color-action-background-primary-default);\n            --font-size: var(--font-title-sm-default-size);\n            --height: 3rem;\n            --line-height: var(--font-body-md-default-line-height);\n            --padding-horizontal: var(--space-content-sm);\n            --padding-vertical: var(--space-internal-lg);\n            --text-color: var(--color-action-text-primary-default);\n            background-color: var(--background);\n            color: var(--text-color);\n            height: var(--height);\n            padding: var(--padding-vertical) var(--padding-horizontal);\n            border: none;\n            border-radius: var(--radius-action);\n            cursor: pointer;\n            display: inline-flex;\n            font-family: inherit;\n            font-size: var(--font-size);\n            font-weight: var(--font-weight-medium);\n            gap: var(--space-internal-sm);\n            justify-content: center;\n            align-items: center;\n            line-height: var(--line-height);\n            text-decoration: none;\n            width: 100%;\n            box-sizing: border-box;\n            margin-bottom: 0 !important;\n            outline: none;\n            vertical-align: middle;\n        }\n        .custom-view-details-btn:hover {\n            --background: var(--color-action-background-primary-focus);\n            --text-color: var(--color-action-text-primary-focus);\n            background-color: var(--background);\n            color: var(--text-color);\n        }\n        .product-tile-body.video-ad-unit-horizontal .custom-view-details-btn {\n        width: auto;\n        flex-grow:1;\n        order: 2;\n        }\n    `;\n\n    function handleShadowTiles() {\n        if (!CONFIG.isInitialized) return;\n        document.querySelectorAll('wc-product-tile').forEach(tile => {\n            const shadow = tile.shadowRoot;\n            if (!shadow) return;\n            const link = shadow.querySelector('a[href*=\"/shop/productdetails/\"]');\n            if (link) {\n                const skuMatch = link.getAttribute(\"href\").match(/\\/productdetails\\/(\\d+)\\//);\n                const sku = skuMatch ? parseInt(skuMatch[1], 10) : null;\n                if (sku && CONFIG.targetSkus.includes(sku)) {\n                    if (!shadow.querySelector('style[data-custom-style]')) {\n                        const st = document.createElement(\"style\");\n                        st.setAttribute(\"data-custom-style\", \"true\");\n                        st.textContent = SHADOW_CSS;\n                        shadow.appendChild(st);\n                    }\n                    const originalCart = shadow.querySelector(\"wc-add-to-cart\");\n                    if (originalCart && !shadow.querySelector(\".custom-view-details-btn\")) {\n                        const newBtn = document.createElement(\"a\");\n                        newBtn.className = \"custom-view-details-btn\";\n                        newBtn.href = link.getAttribute(\"href\");\n                        newBtn.textContent = CONFIG.buttonLabel;\n                        newBtn.addEventListener('click', () => triggerTracking(sku));\n                        originalCart.replaceWith(newBtn);\n                    }\n                }\n            }\n        });\n    }\n\n    function handleStandardLists() {\n        if (!CONFIG.isInitialized) return;\n        document.querySelectorAll('#sf-product-varieties-list li').forEach(li => {\n            const skuInput = li.querySelector('.sf-stockcode');\n            const skuStr = skuInput ? skuInput.value : li.id?.split('-').pop();\n            const sku = parseInt(skuStr, 10);\n            if (!isNaN(sku) && CONFIG.targetSkus.includes(sku)) {\n                const cartContainer = li.querySelector('.sf-variety-addtocart-container');\n                const oosContainer = li.querySelector('.sf-variety-oos-container');\n                if (cartContainer) {\n                    const origBtn = cartContainer.querySelector('.cartControls-addButton');\n                    if (origBtn) origBtn.remove(); \n                }\n                const targetContainer = (cartContainer && getComputedStyle(cartContainer).display !== 'none') ? cartContainer : oosContainer;\n                if (targetContainer && !li.querySelector('.custom-view-details-btn-standard')) {\n                    const newBtn = document.createElement('a');\n                    newBtn.className = \"custom-view-details-btn-standard\";\n                    newBtn.href = \"/shop/productdetails/\" + sku;\n                    newBtn.textContent = CONFIG.buttonLabel;\n                    newBtn.addEventListener('click', () => triggerTracking(sku));\n                    targetContainer.prepend(newBtn);\n                }\n            }\n        });\n\n        document.querySelectorAll('shared-product-alternative-list-item').forEach(alt => {\n            const link = alt.querySelector('.list-item-title-link');\n            if (link) {\n                const href = link.getAttribute(\"href\");\n                const skuMatch = href.match(/\\/productdetails\\/(\\d+)\\//);\n                const sku = skuMatch ? parseInt(skuMatch[1], 10) : null;\n                if (sku && CONFIG.targetSkus.includes(sku)) {\n                    const cartBtnWrap = alt.querySelector('.list-item-cart-button');\n                    if (cartBtnWrap && !cartBtnWrap.querySelector('.custom-view-details-btn-standard')) {\n                        const cartControls = cartBtnWrap.querySelector('shared-cart-controls');\n                        if (cartControls) cartControls.remove(); \n                        const newBtn = document.createElement('a');\n                        newBtn.className = \"custom-view-details-btn-standard\";\n                        newBtn.href = href;\n                        newBtn.textContent = CONFIG.buttonLabel;\n                        newBtn.addEventListener('click', () => triggerTracking(sku));\n                        cartBtnWrap.appendChild(newBtn);\n                    }\n                }\n            }\n        });\n    }\n\n    function handleCmpProductCards() {\n        if (!CONFIG.isInitialized) return;\n\n        // 1. Handle Active Add to Cart components\n        document.querySelectorAll('cmp-add-to-cart-button:not(.js-custom-replaced)').forEach(cartComp => {\n            const skuStr = cartComp.getAttribute('stockcode');\n            replaceCmpButton(cartComp, skuStr);\n        });\n\n        // 2. Handle Static Out of Stock buttons\n        document.querySelectorAll('.btn-outofstock:not(.js-custom-replaced)').forEach(oosBtn => {\n            const parentCard = oosBtn.closest('.cmp-product-card');\n            if (!parentCard) return;\n\n            // Attempt to find SKU from \"Save to list\" button ID or product link\n            const saveToListBtn = parentCard.querySelector('.btn-savetolist');\n            const productLink = parentCard.querySelector('a.cmp-product-card-image-wrapper');\n            \n            let skuStr = null;\n            if (saveToListBtn && saveToListBtn.id) {\n                skuStr = saveToListBtn.id.split('-').reverse()[1]; // Extracts SKU from ID format\n            } else if (productLink) {\n                const match = productLink.href.match(/\\/productdetails\\/(\\d+)\\//);\n                skuStr = match ? match[1] : null;\n            }\n\n            if (skuStr) replaceCmpButton(oosBtn, skuStr);\n        });\n    }\n\n    function replaceCmpButton(targetElement, skuStr) {\n        const sku = parseInt(skuStr, 10);\n        if (sku && CONFIG.targetSkus.includes(sku)) {\n            const newBtn = document.createElement('a');\n            newBtn.className = \"btn js-custom-replaced\"; \n            newBtn.href = \"/shop/productdetails/\" + sku;\n            newBtn.textContent = CONFIG.buttonLabel;\n            newBtn.style.display = \"flex\";\n            newBtn.style.width = \"100%\";\n            newBtn.style.justifyContent = \"center\";\n            newBtn.style.alignItems = \"center\";\n            newBtn.style.textDecoration = \"none\";\n            newBtn.style.opacity = \"1\"; // Ensure it's visible even if replacing a disabled button\n            newBtn.style.cursor = \"pointer\";\n\n            newBtn.addEventListener('click', () => triggerTracking(sku));\n            targetElement.replaceWith(newBtn);\n        }\n    }\n\n    function runAllHandlers() {\n        handleShadowTiles();\n        handleStandardLists();\n        handleCmpProductCards();\n    }\n\n    async function init() {\n        const observer = new MutationObserver(runAllHandlers);\n        observer.observe(document.documentElement, { childList: true, subtree: true });\n\n        try {\n            const response = await fetch(CONFIG.skuEndpoint);\n            if (!response.ok) return;\n            const data = await response.json();\n            if (Array.isArray(data)) {\n                CONFIG.targetSkus = data;\n                CONFIG.isInitialized = true;\n                runAllHandlers();\n            }\n        } catch (e) {\n            console.error(\"[SKU-Manager] Init error:\", e);\n        }\n    }\n\n    if (document.readyState === 'loading') {\n        document.addEventListener('DOMContentLoaded', init);\n    } else {\n        init();\n    }\n\n})();\n\u003C/script>\u003Cscript>\n  \n  (function () {\n  const stockCodes = [\n    173068, 173085, 173086, 236757, 173078, 173092, 173072, 173080, 173069,\n    173074, 173067, 173089, 173090, 173088, 173091, 173066, 173070, 173076,\n    173071, 173073, 173084, 173077, 173083, 172968, 172971, 172969, 172970,\n    173064, 173065, 173063, 173054, 173093, 173056, 173062, 173055, 172967,\n    175004, 175342, 174863, 174289, 175005, 174861, 174287, 113437, 113435,\n    113436, 113572, 113574, 113573, 113560, 113561, 113559, 113556, 113557,\n    113558, 113555, 113553, 113554, 115168, 115118, 115121, 115119, 115171,\n    115117, 115169, 115120, 115167, 115162, 115815, 115803, 115782, 115788,\n    115145, 115495, 115786, 115785, 115784, 115787, 115081, 115790, 115806,\n    115791, 115802, 115147, 115783, 115821, 115497, 236533, 236532, 236535,\n    236547, 236543, 236536, 236539, 236537, 236545, 236541, 236538, 236546,\n    236544, 236540, 236542, 236852, 236671, 236745, 236752, 236750, 236751,\n    236743, 236754, 236986, 236984, 236985, 236758, 236853, 236757, 236761,\n    236753, 236755, 236744, 236802, 236746, 236803, 236747, 236748, 236749,\n    236756, 236760, 236759, 239001, 239004, 238810, 238985, 238368, 238428,\n    58282, 57146, 57147, 60708, 56961, 57142, 57145, 58283, 57143, 56959, 57149,\n    58284, 58286, 58288, 58285, 57601, 57600, 57144, 57001, 57000, 56958, 58287,\n    58290, 58289, 58291, 59797, 67890, 67891, 67932, 764671, 764629, 764662,\n    764627, 764970, 764628, 764620, 764663, 764637, 764972, 662355, 662352,\n    662357, 800668, 800710, 795624, 795830, 800708, 799829, 800718, 795714,\n    764644, 764635, 764638, 764636, 800713, 645082, 662356, 115170, 173081,\n    221483, 324298, 336254, 336261, 336265, 336268, 336531, 365199, 365200,\n    369639, 521227, 521229, 521403, 521406, 521407, 521409, 521432, 521433,\n    521434, 521481, 521482, 60171, 60272, 60273, 644997, 644998, 644999, 645060,\n    645079, 645080, 645081, 645083, 645084, 645087, 645100, 645101, 662339,\n    662351, 662353, 662354, 662358, 707097, 707140, 707141, 707143, 707145,\n    747047, 749174, 749213, 776709, 778860, 778868, 778873, 778960, 797759,\n    797760, 798051, 798052, 798054, 798061, 798147, 927985, 927986, 927987,\n    928019, 928075, 928076, 928077, 928078, 928079, 928080, 928081, 928124,\n    928125, 928126, 928127, 928128, 928130, 928131, 928132, 928163, 928164,\n    928165, 928166, 932993, 956106, 956145, 336259, 336681, 365201, 705410,\n    759837,\n  ];\n\n  if (window.location.pathname.indexOf('shop/productdetails/') >= 0) {\n    const stockCode = parseInt(window.location.pathname.split('/')[3]);\n    if (stockCodes.indexOf(stockCode) >= 0) {\n      // Add the no index meta tag\n      const noIndexMetaTag = document.createElement('meta');\n      noIndexMetaTag.name = 'robots';\n      noIndexMetaTag.content = 'noindex';\n      document.head.appendChild(noIndexMetaTag);\n    }\n  }\n})();\n\n\n\u003C/script>\u003Cscript>\n    (function() {\n    \"use strict\";\n    async function asyncWaitForVariable(path, timeout = 5e3, interval = 200) {\n        function getNestedValue(path) {\n            const parts = path.split(\".\");\n            let current = window;\n            for (const part of parts) {\n                current = current[part];\n                if (typeof current === \"undefined\") return;\n            }\n            return current;\n        }\n        return new Promise((resolve, reject) => {\n            const timer = setInterval(() => {\n                const value = getNestedValue(path);\n                if (typeof value !== \"undefined\") {\n                    clearInterval(timer);\n                    resolve(value);\n                }\n            }, interval);\n            setTimeout(() => {\n                clearInterval(timer);\n                reject(new Error(`Variable '' not found within ms`));\n            }, timeout);\n        });\n    }\n    async function asyncWaitForElement(root, selector, timeout = 5e3, interval = 200) {\n        let rootElement = root;\n        let startTime = Date.now();\n        return new Promise((resolve, reject) => {\n            const intervalId = setInterval(() => {\n                const initialElement = rootElement.querySelector(selector);\n                if (initialElement) {\n                    resolve(initialElement);\n                    return;\n                }\n                const element = rootElement.querySelector(selector);\n                if (element) {\n                    clearInterval(intervalId);\n                    resolve(element);\n                } else if (Date.now() - startTime >= timeout) {\n                    clearInterval(intervalId);\n                    reject();\n                }\n            }, interval);\n        });\n    }\n    (async () => {\n        let rexp293 = {\n            init: async () => {\n                if (window.location.href.indexOf(\"/\") == -1) return;\n                const modificationArea = await asyncWaitForElement(document, '[class^=\"edm_edm-container_\"]').catch(err => null);\n                if (!modificationArea) return;\n                const pageAttributes = await asyncWaitForVariable(\"wowDataLayer.productDetail.AdditionalAttributes\");\n                const piescategorynamesjson = pageAttributes.piescategorynamesjson;\n                const piessubcategorynamesjson = pageAttributes.piessubcategorynamesjson;\n                const piesdepartmentnamesjson = pageAttributes.piesdepartmentnamesjson;\n                const combinedjson = piescategorynamesjson + \"|\" + piessubcategorynamesjson + \"|\" + piesdepartmentnamesjson;\n                const dataRules = [ [ \"Baby\", \"Nursery & Sleeping\", \"Decor\" ], [ \"Everyday Market\", \"Baby\", \"Baby Furniture\" ], [ \"Everyday Market\", \"Home Decor & Furniture\", \"Bedroom\" ], [ \"Everyday Market\", \"Home Decor & Furniture\", \"Kids Furniture\" ], [ \"Everyday Market\", \"Home Decor & Furniture\", \"Kitchen & Dining\" ], [ \"Everyday Market\", \"Home Decor & Furniture\", \"Living Room\" ], [ \"Everyday Market\", \"Home Decor & Furniture\", \"Office\" ], [ \"Home & Lifestyle\", \"Home Decor & Furniture\" ], [ \"Home & Lifestyle\", \"Home Decor & Furniture\", \"Bedroom\" ], [ \"Home & Lifestyle\", \"Home Decor & Furniture\", \"Kids Furniture\" ], [ \"Home & Lifestyle\", \"Home Decor & Furniture\", \"Kitchen & Dining\" ], [ \"Home & Lifestyle\", \"Home Decor & Furniture\", \"Living Room\" ], [ \"Home & Lifestyle\", \"Stationery & Office Supplies\", \"Office Furniture\" ] ];\n                function ruleMatches(ruleArr) {\n                    return ruleArr.every(term => combinedjson.indexOf(term) !== -1);\n                }\n                const matchesAnyRule = dataRules.some(ruleMatches);\n                if (!matchesAnyRule) return;\n                if (document.querySelector(\".rexp293\")) return;\n                modificationArea.classList.add(\"rexp293\");\n                const message = `\u003Cdiv class=\"product-details-panel_component_alert-container__xYxwo\">\u003Cdiv role=\"status\" class=\"alert_core-alert__wwWHq\">\\n      \u003Cimg style=\"height: 1.5rem;\\n    max-width: 1.5rem;\\n    min-width: 1.5rem;\\n    width: 1.5rem;\" src=\"https://cdn0.woolworths.media/content/content/warning-symbol.png\"/>\\n      \u003Cimg style=\"height: 1.5rem;\\n    max-width: 1.5rem;\\n    min-width: 1.5rem;\\n    width: 1.5rem;\" src=\"https://cdn0.woolworths.media/content/content/tipping-symbol.png\"/>\\n\\n       \u003Cdiv class=\"alert_core-alert-container__Xo1_Z\">\u003Cdiv class=\"alert_core-alert-title__X5LkY\">WARNING! TIPPING HAZARD\u003C/div>\u003Cp class=\"alert_core-alert-description__HzNLm\">Children have died from furniture tipping over.\\n\u003Cul>\\n  \u003Cli>\u003Cstrong>ALWAYS\u003C/strong> secure this furniture with an anchor device.\u003C/li>\\n  \u003Cli>\u003Cstrong>NEVER\u003C/strong> allow children to stand, climb, or hang on drawers, doors or shelves.\u003C/li>\\n  \u003Cli>\u003Cstrong>NEVER\u003C/strong> open more than one drawer at the time.\u003C/li>\\n  \u003Cli>\u003Cstrong>ALWAYS\u003C/strong> place heaviest items in the lowest drawers.\u003C/li>\\n  \u003Cli>\u003Cstrong>NEVER\u003C/strong> place a TV on any furniture other than an entertainment unit intended for this purpose.\u003C/li>\\n  \u003Cli>\u003Cstrong>ALWAYS\u003C/strong> secure your TV with an anchor device.\u003C/li>\\n\u003C/ul>\u003C/p>\u003C/div>\u003C/div>\u003C/div>`;\n                let accordionArea = document.querySelector('[class^=\"accordion_core-accordion-item__\"]');\n                accordionArea.insertAdjacentHTML(\"beforebegin\", message);\n            },\n            config: {\n                version: \"a\",\n                ticket: \"rexp293\"\n            }\n        };\n        rexp293.init();\n    })();\n})();\n\n\u003C/script>\u003Cscript>\n  (function () {\n    \"use strict\";\n    function rexDebug() {\n      let debugValue = localStorage.getItem(\"rex-debug\");\n      return debugValue === \"true\";\n    }\n    function ready(observableTarget, selector, id, fn) {\n      let listeners = [],\n        doc = window.document,\n        MutationObserver =\n          window.MutationObserver || window.WebKitMutationObserver,\n        observer;\n      listeners.push({\n        selector: selector,\n        fn: fn,\n      });\n      if (!observer) {\n        observer = new MutationObserver(check);\n        observer.observe(document.querySelector(observableTarget), {\n          childList: true,\n          subtree: true,\n        });\n      }\n      check();\n      function check() {\n        for (\n          var i = 0, len = listeners.length, listener, elements;\n          i \u003C len;\n          i++\n        ) {\n          listener = listeners[i];\n          elements = doc.querySelectorAll(listener.selector);\n          for (var j = 0, jLen = elements.length, element; j \u003C jLen; j++) {\n            element = elements[j];\n            if (!element[id + \"ready\"]) {\n              element[id + \"ready\"] = true;\n              listener.fn.call(element, element);\n            }\n          }\n        }\n      }\n    }\n    (async () => {\n      let rexp361 = {\n        buildData: (item) => {\n          const labels = Array.from(\n            document.querySelectorAll(\".day-description\"),\n            (el) => el.innerText.trim(),\n          );\n          const dayWindows = item;\n          let finalOutput = labels.reduce((acc, label, index) => {\n            acc[label] = {\n              ...dayWindows[index],\n              label: label,\n            };\n            return acc;\n          }, {});\n          const today = new Date();\n          const daysOfWeek = [\n            \"Sun\",\n            \"Mon\",\n            \"Tue\",\n            \"Wed\",\n            \"Thu\",\n            \"Fri\",\n            \"Sat\",\n            \"Sun\",\n          ];\n          const currentDay = daysOfWeek[today.getDay()];\n          const tomorrow = daysOfWeek[today.getDay() + 1];\n          finalOutput[\"Today\"].label = currentDay;\n          finalOutput[\"Tomorrow\"].label = tomorrow;\n          rexp361.debug && console.log(finalOutput);\n          return finalOutput;\n        },\n        calculateLabels: (dayData, page) => {\n\n          setTimeout(() => {\n            const dayDescriptions =\n              document.querySelectorAll(\".day-description\");\n  \n          \n            dayDescriptions.forEach((desc) => {\n              const label = desc.innerText.trim();\n              const windows = dayData[label];\n              if (windows && windows.label) {\n                let serviceFeeEligible = false;\n                if (windows.label === \"Sun\") serviceFeeEligible = true;\n                if (windows.IsPublicHoliday == true) serviceFeeEligible = true;\n                let closed = desc\n                  .closest(\"label\")\n                  .classList.contains(\"closed\");\n                if (serviceFeeEligible && !closed) {\n                  let newLabel = `\n\u003Cdiv class=\"ela1257-label\">\n  +$2 Service fee\n\u003C/div>\n\n\u003Cstyle>\n    /* Container adjustments */\n    .dates-container-inner {\n        padding-top: 10px !important;\n    }\n    /* The Service Fee Label - Consolidated Styles */\n    .ela1257-label {\n        position: absolute;\n        bottom: -15px;\n        background-color: white;\n        color: #25251f;\n        border: 1px solid var(--color-interface-border-default);\n        border-radius: 2px;\n        font-size: var(--font-caption-sm-light-size);\n       \n        font-family: var(--font-family-roboto);\n        padding: .125rem .25rem;\n        width: 102%;\n    }\n    /* Time Slot Navigation Arrows */\n    wow-time-slot-selector .nav-arrow-container.show-arrow {\n        top: -10px;\n        height: 102px;\n    }\n    wow-time-slot-selector .nav-arrow.show-arrow {\n        height: 102px !important;\n    }\n    label.day.selected .ela1257-label {\n        border-color: var(--color-interface-border-highlight-medium);\n        background: var(--color-primitive-apple-10);\n    }\n\u003C/style>\n\n`;\n                  desc\n                    .closest(\"label\")\n                    .insertAdjacentHTML(\"beforeend\", newLabel);\n\n                  if (typeof utag !== \"undefined\") {\n                    utag.link({\n                      \"event.Category\": `rexp361_servicefee_${page}`,\n                      \"event.Action\": \"show\",\n                      \"event.Label\": \"rexp361_servicefee_variant\",\n                    });\n                  }\n\n                  if (rexp361.isCheckout)\n                    document\n                      .querySelectorAll(\".dates-container-outer .nav-arrow\")\n                      .forEach((item) => {\n                        item.setAttribute(\n                          \"style\",\n                          \"    margin: 12px 0;height: calc(94px + 24px);\",\n                        );\n                      });\n                  else\n                    document\n                      .querySelectorAll(\".dates-container-outer .nav-arrow\")\n                      .forEach((item) => {\n                        item.setAttribute(\n                          \"style\",\n                          \"    height: calc(94px + 24px) !important;\",\n                        );\n                      });\n                }\n              }\n            });\n          }, 1000);\n        },\n        init: async () => {\n          \n          rexp361.debug = rexDebug();\n          rexp361.debug && console.log(\"rexp361: debug\");\n          if (document.querySelector(\".rexp361\")) return;\n          let isCheckout = window.location.href.indexOf(\"/checkout\") > -1;\n          rexp361.isCheckout = isCheckout;\n          if (isCheckout) {\n            let observableTarget = \"#checkout-timePanel\";\n            if (!document.querySelector(observableTarget)) return;\n            ready(\n              observableTarget,\n              \".dates-container-outer\",\n              \"rexp361\",\n              (item) => {\n                let dayData = rexp361.buildData(wowDataLayer.deliveryWindows);\n                document.addEventListener(\"wowDataLayerUpdated\", function (e) {\n          \n                   if (e?.detail?.eventName !== \"deliveryWindows\") return;\n                  if (\n                    document.querySelectorAll(\n                      \"wow-checkout-fulfilment-summary .headline-medium\",\n                    ).length == 0\n                  )\n                    return;\n/*\n                  if (\n                    document.querySelector(\n                      \"wow-checkout-fulfilment-summary .headline-medium\",\n                    ).innerText !== \"Delivery to:\"\n                  )\n                    return;\n                    */\n                  let dayData = rexp361.buildData(e.detail.eventValue);\n                  rexp361.calculateLabels(dayData, \"checkout\");\n                });\n                rexp361.debug && console.log(dayData);\n\n                if (\n                  document.querySelectorAll(\n                    \"wow-checkout-fulfilment-summary .headline-medium\",\n                  ).length == 0\n                )\n                  return;\n                /*\n                if (\n                  document.querySelector(\n                    \"wow-checkout-fulfilment-summary .headline-medium\",\n                  ).innerText !== \"Delivery to:\"\n                )\n                  return;\n                  */\n                rexp361.calculateLabels(dayData, \"checkout\");\n              },\n            );\n          } else {\n            let observableTarget = \"#right-panel\";\n            if (!document.querySelector(observableTarget)) return;\n            ready(\n              observableTarget,\n              \"wow-side-cart-time-slots-panel .dates-container-outer\",\n              \"rexp361\",\n              (item) => {\n                let dayData = rexp361.buildData(wowDataLayer.deliveryWindows);\n                document.addEventListener(\"wowDataLayerUpdated\", function (e) {\n                   if (e?.detail?.eventName !== \"deliveryWindows\") return;\n\n                  if (\n                    document.querySelectorAll(\"#fulfilment-method\").length ==\n                      0 \n                  )\n                    return;\n                  let dayData = rexp361.buildData(e.detail.eventValue);\n                  rexp361.calculateLabels(dayData, \"FMS\");\n                });\n                rexp361.debug && console.log(dayData);\n\n                if (\n                  document.querySelectorAll(\"#fulfilment-method\").length == 0 \n                )\n                  return;\n                rexp361.calculateLabels(dayData, \"FMS\");\n              },\n            );\n          }\n        },\n        config: {\n          version: \"a\",\n          ticket: \"rexp361\",\n          limitStates: true,\n          debug: false,\n        },\n      };\n      rexp361.init();\n    })();\n  })();\n\u003C/script>\u003Cscript>\nwindow.dispatchEvent(new CustomEvent('CRO_Experiment_Event', {\n      detail: {\n        key: 'cro_SPUD-3113_rangingExperiment',\n        endDate: '2024-04-02 13:00:00.000',\n        experiment: true\n      }\n}));\n\u003C/script>\u003Cscript>\nwindow.dispatchEvent(new CustomEvent('CRO_Experiment_Event', {\n  detail:{ \n    key:'search_variant_flags', \n    endDate: ['2026-04-06T13:00:00.00Z'], \n    experiment:{'EnableProductBoostExperiment': true}\n  }\n}));\n\u003C/script>\u003Cstyle id=\"global-sku-styles\">\n    /* Varieties & Alternative Button Styling (Standard DOM) */\n    .custom-view-details-btn-standard {\n        --background: var(--color-action-background-primary-default);\n        --text-color: var(--color-action-text-primary-default);\n        background-color: var(--background) !important;\n        color: var(--text-color) !important;\n        width: 100% !important;\n        height: 40px !important;\n        padding: 0 !important;\n        font-size: 14px !important;\n        border-radius: 36px !important;\n        border: none !important;\n        cursor: pointer !important;\n        display: inline-flex !important;\n        align-items: center !important;\n        justify-content: center !important;\n        font-family: inherit !important;\n        font-weight: 600 !important;\n        text-decoration: none !important;\n        box-sizing: border-box !important;\n        margin-top: 10px !important;\n    }\n\n    .custom-view-details-btn-standard:hover, \n    .custom-view-details-btn-standard:focus {\n        --background: var(--color-action-background-primary-focus);\n        --text-color: var(--color-action-text-primary-focus);\n        background-color: var(--background) !important;\n        color: var(--text-color) !important;\n    }\n\u003C/style>\u003Cscript>\n(function () {\n    'use strict';\n\n    const CONFIG = {\n        skuEndpoint: 'https://cdn0.woolworths.media/wowssr/assets/tga-sku.json',\n        buttonLabel: 'View Details',\n        targetSkus: [],\n        isInitialized: false,\n        tracking: {\n            enabled: true,\n            category: 'SKU Replacement',\n            action: 'View Details Click',\n            labelPrefix: 'SKU: '\n        }\n    };\n\n    function triggerTracking(sku) {\n        if (!CONFIG.tracking.enabled) return;\n        if (typeof (utag) !== 'undefined') { \n            utag.link({ \n                'event.Category': CONFIG.tracking.category, \n                'event.Action': CONFIG.tracking.action, \n                'event.Label': CONFIG.tracking.labelPrefix + sku \n            });\n        }\n    }\n\n    const SHADOW_CSS = `\n        .custom-view-details-btn {\n            --background: var(--color-action-background-primary-default);\n            --font-size: var(--font-title-sm-default-size);\n            --height: 3rem;\n            --line-height: var(--font-body-md-default-line-height);\n            --padding-horizontal: var(--space-content-sm);\n            --padding-vertical: var(--space-internal-lg);\n            --text-color: var(--color-action-text-primary-default);\n            background-color: var(--background);\n            color: var(--text-color);\n            height: var(--height);\n            padding: var(--padding-vertical) var(--padding-horizontal);\n            border: none;\n            border-radius: var(--radius-action);\n            cursor: pointer;\n            display: inline-flex;\n            font-family: inherit;\n            font-size: var(--font-size);\n            font-weight: var(--font-weight-medium);\n            gap: var(--space-internal-sm);\n            justify-content: center;\n            align-items: center;\n            line-height: var(--line-height);\n            text-decoration: none;\n            width: 100%;\n            box-sizing: border-box;\n            margin-bottom: 0 !important;\n            outline: none;\n            vertical-align: middle;\n        }\n        .custom-view-details-btn:hover {\n            --background: var(--color-action-background-primary-focus);\n            --text-color: var(--color-action-text-primary-focus);\n            background-color: var(--background);\n            color: var(--text-color);\n        }\n        .product-tile-body.video-ad-unit-horizontal .custom-view-details-btn {\n        width: auto;\n        flex-grow:1;\n        order: 2;\n        }\n    `;\n\n    function handleShadowTiles() {\n        if (!CONFIG.isInitialized) return;\n        document.querySelectorAll('wc-product-tile').forEach(tile => {\n            const shadow = tile.shadowRoot;\n            if (!shadow) return;\n            const link = shadow.querySelector('a[href*=\"/shop/productdetails/\"]');\n            if (link) {\n                const skuMatch = link.getAttribute(\"href\").match(/\\/productdetails\\/(\\d+)\\//);\n                const sku = skuMatch ? parseInt(skuMatch[1], 10) : null;\n                if (sku && CONFIG.targetSkus.includes(sku)) {\n                    if (!shadow.querySelector('style[data-custom-style]')) {\n                        const st = document.createElement(\"style\");\n                        st.setAttribute(\"data-custom-style\", \"true\");\n                        st.textContent = SHADOW_CSS;\n                        shadow.appendChild(st);\n                    }\n                    const originalCart = shadow.querySelector(\"wc-add-to-cart\");\n                    if (originalCart && !shadow.querySelector(\".custom-view-details-btn\")) {\n                        const newBtn = document.createElement(\"a\");\n                        newBtn.className = \"custom-view-details-btn\";\n                        newBtn.href = link.getAttribute(\"href\");\n                        newBtn.textContent = CONFIG.buttonLabel;\n                        newBtn.addEventListener('click', () => triggerTracking(sku));\n                        originalCart.replaceWith(newBtn);\n                    }\n                }\n            }\n        });\n    }\n\n    function handleStandardLists() {\n        if (!CONFIG.isInitialized) return;\n        document.querySelectorAll('#sf-product-varieties-list li').forEach(li => {\n            const skuInput = li.querySelector('.sf-stockcode');\n            const skuStr = skuInput ? skuInput.value : li.id?.split('-').pop();\n            const sku = parseInt(skuStr, 10);\n            if (!isNaN(sku) && CONFIG.targetSkus.includes(sku)) {\n                const cartContainer = li.querySelector('.sf-variety-addtocart-container');\n                const oosContainer = li.querySelector('.sf-variety-oos-container');\n                if (cartContainer) {\n                    const origBtn = cartContainer.querySelector('.cartControls-addButton');\n                    if (origBtn) origBtn.remove(); \n                }\n                const targetContainer = (cartContainer && getComputedStyle(cartContainer).display !== 'none') ? cartContainer : oosContainer;\n                if (targetContainer && !li.querySelector('.custom-view-details-btn-standard')) {\n                    const newBtn = document.createElement('a');\n                    newBtn.className = \"custom-view-details-btn-standard\";\n                    newBtn.href = \"/shop/productdetails/\" + sku;\n                    newBtn.textContent = CONFIG.buttonLabel;\n                    newBtn.addEventListener('click', () => triggerTracking(sku));\n                    targetContainer.prepend(newBtn);\n                }\n            }\n        });\n\n        document.querySelectorAll('shared-product-alternative-list-item').forEach(alt => {\n            const link = alt.querySelector('.list-item-title-link');\n            if (link) {\n                const href = link.getAttribute(\"href\");\n                const skuMatch = href.match(/\\/productdetails\\/(\\d+)\\//);\n                const sku = skuMatch ? parseInt(skuMatch[1], 10) : null;\n                if (sku && CONFIG.targetSkus.includes(sku)) {\n                    const cartBtnWrap = alt.querySelector('.list-item-cart-button');\n                    if (cartBtnWrap && !cartBtnWrap.querySelector('.custom-view-details-btn-standard')) {\n                        const cartControls = cartBtnWrap.querySelector('shared-cart-controls');\n                        if (cartControls) cartControls.remove(); \n                        const newBtn = document.createElement('a');\n                        newBtn.className = \"custom-view-details-btn-standard\";\n                        newBtn.href = href;\n                        newBtn.textContent = CONFIG.buttonLabel;\n                        newBtn.addEventListener('click', () => triggerTracking(sku));\n                        cartBtnWrap.appendChild(newBtn);\n                    }\n                }\n            }\n        });\n    }\n\n    function handleCmpProductCards() {\n        if (!CONFIG.isInitialized) return;\n\n        // 1. Handle Active Add to Cart components\n        document.querySelectorAll('cmp-add-to-cart-button:not(.js-custom-replaced)').forEach(cartComp => {\n            const skuStr = cartComp.getAttribute('stockcode');\n            replaceCmpButton(cartComp, skuStr);\n        });\n\n        // 2. Handle Static Out of Stock buttons\n        document.querySelectorAll('.btn-outofstock:not(.js-custom-replaced)').forEach(oosBtn => {\n            const parentCard = oosBtn.closest('.cmp-product-card');\n            if (!parentCard) return;\n\n            // Attempt to find SKU from \"Save to list\" button ID or product link\n            const saveToListBtn = parentCard.querySelector('.btn-savetolist');\n            const productLink = parentCard.querySelector('a.cmp-product-card-image-wrapper');\n            \n            let skuStr = null;\n            if (saveToListBtn && saveToListBtn.id) {\n                skuStr = saveToListBtn.id.split('-').reverse()[1]; // Extracts SKU from ID format\n            } else if (productLink) {\n                const match = productLink.href.match(/\\/productdetails\\/(\\d+)\\//);\n                skuStr = match ? match[1] : null;\n            }\n\n            if (skuStr) replaceCmpButton(oosBtn, skuStr);\n        });\n    }\n\n    function replaceCmpButton(targetElement, skuStr) {\n        const sku = parseInt(skuStr, 10);\n        if (sku && CONFIG.targetSkus.includes(sku)) {\n            const newBtn = document.createElement('a');\n            newBtn.className = \"btn js-custom-replaced\"; \n            newBtn.href = \"/shop/productdetails/\" + sku;\n            newBtn.textContent = CONFIG.buttonLabel;\n            newBtn.style.display = \"flex\";\n            newBtn.style.width = \"100%\";\n            newBtn.style.justifyContent = \"center\";\n            newBtn.style.alignItems = \"center\";\n            newBtn.style.textDecoration = \"none\";\n            newBtn.style.opacity = \"1\"; // Ensure it's visible even if replacing a disabled button\n            newBtn.style.cursor = \"pointer\";\n\n            newBtn.addEventListener('click', () => triggerTracking(sku));\n            targetElement.replaceWith(newBtn);\n        }\n    }\n\n    function runAllHandlers() {\n        handleShadowTiles();\n        handleStandardLists();\n        handleCmpProductCards();\n    }\n\n    async function init() {\n        const observer = new MutationObserver(runAllHandlers);\n        observer.observe(document.documentElement, { childList: true, subtree: true });\n\n        try {\n            const response = await fetch(CONFIG.skuEndpoint);\n            if (!response.ok) return;\n            const data = await response.json();\n            if (Array.isArray(data)) {\n                CONFIG.targetSkus = data;\n                CONFIG.isInitialized = true;\n                runAllHandlers();\n            }\n        } catch (e) {\n            console.error(\"[SKU-Manager] Init error:\", e);\n        }\n    }\n\n    if (document.readyState === 'loading') {\n        document.addEventListener('DOMContentLoaded', init);\n    } else {\n        init();\n    }\n\n})();\n\u003C/script>\u003Cscript>\n  \n  (function () {\n  const stockCodes = [\n    173068, 173085, 173086, 236757, 173078, 173092, 173072, 173080, 173069,\n    173074, 173067, 173089, 173090, 173088, 173091, 173066, 173070, 173076,\n    173071, 173073, 173084, 173077, 173083, 172968, 172971, 172969, 172970,\n    173064, 173065, 173063, 173054, 173093, 173056, 173062, 173055, 172967,\n    175004, 175342, 174863, 174289, 175005, 174861, 174287, 113437, 113435,\n    113436, 113572, 113574, 113573, 113560, 113561, 113559, 113556, 113557,\n    113558, 113555, 113553, 113554, 115168, 115118, 115121, 115119, 115171,\n    115117, 115169, 115120, 115167, 115162, 115815, 115803, 115782, 115788,\n    115145, 115495, 115786, 115785, 115784, 115787, 115081, 115790, 115806,\n    115791, 115802, 115147, 115783, 115821, 115497, 236533, 236532, 236535,\n    236547, 236543, 236536, 236539, 236537, 236545, 236541, 236538, 236546,\n    236544, 236540, 236542, 236852, 236671, 236745, 236752, 236750, 236751,\n    236743, 236754, 236986, 236984, 236985, 236758, 236853, 236757, 236761,\n    236753, 236755, 236744, 236802, 236746, 236803, 236747, 236748, 236749,\n    236756, 236760, 236759, 239001, 239004, 238810, 238985, 238368, 238428,\n    58282, 57146, 57147, 60708, 56961, 57142, 57145, 58283, 57143, 56959, 57149,\n    58284, 58286, 58288, 58285, 57601, 57600, 57144, 57001, 57000, 56958, 58287,\n    58290, 58289, 58291, 59797, 67890, 67891, 67932, 764671, 764629, 764662,\n    764627, 764970, 764628