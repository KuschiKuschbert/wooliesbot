# WoolesBot - Environment Configuration
# 1. Copy: cp .env.example .env
# 2. Fill in your values below

# ── Telegram ─────────────────────────────────────────────────────────────────
# Required for Telegram notifications and /shop bot commands (no defaults in code).
# If this file was ever public: open @BotFather → /revoke → paste the new TELEGRAM_TOKEN below.
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Verbose scraper logs (optional; default INFO)
# WOOLIESBOT_DEBUG=1

# ── Cloud write API (optional — local manual tests only) ──────────────────────
# Dev-only helper for manual curl tests against your Worker.
# Production value must live in Worker/GitHub secrets, not in repo files.
# Same value as WOOLIESBOT_WRITE_SECRET on the Worker; never commit real secrets.
# WOOLIESBOT_WRITE_SECRET=

# Telegram noise control (optional)
# WOOLIESBOT_TELEGRAM_STARTUP=0   # suppress "Supervisor active" on daemon start (default: send)
# WOOLIESBOT_TELEGRAM_ERRORS=1  # also Telegram-alert on run_report failures during silent scheduled scrapes

# ── Scraper tuning (optional; see chef_os.py) ─────────────────────────────────
# Woolworths: sequential curl_cffi with human-like pacing (1.5-4s jitter, batch pauses).
# Coles: BFF API sequential; Chrome fallback only when needed.
# WOOLIESBOT_CFFI_HTTP_RETRIES=4
# WOOLIESBOT_CHROME_FALLBACK_THRESHOLD=0.60
# WOOLIESBOT_OUTLIER_DEVIATION_PCT=40
# WOOLIESBOT_ADAPTIVE=1
# WOOLIESBOT_METRICS_HISTORY=30
#
# (Removed unused knobs: WOOLIESBOT_CFFI_BATCH_WORKERS / WOOLIESBOT_CFFI_MAX_WORKERS — scraping stays single-session sequential.)
#
# Pacing — jitter between each request (seconds)
# WOOLIESBOT_REQUEST_JITTER_MIN_SEC=1.5
# WOOLIESBOT_REQUEST_JITTER_MAX_SEC=4.0
#
# Batching — pause between groups of N items + session rotation
# WOOLIESBOT_BATCH_SIZE=20
# WOOLIESBOT_BATCH_PAUSE_MIN_SEC=20
# WOOLIESBOT_BATCH_PAUSE_MAX_SEC=40
#
# Circuit breaker — pause + new session after N consecutive failures
# WOOLIESBOT_CIRCUIT_BREAKER_STREAK=3
# WOOLIESBOT_CIRCUIT_BREAKER_PAUSE_SEC=120
#
# Homepage / PDP HTML length floors (Akamai shells vary; raise if you see false positives)
# WOOLIESBOT_WOOLIES_WARMUP_MIN_CHARS=3500
# WOOLIESBOT_PDP_MIN_HTML_CHARS=4500
#
# Optional proxies (residential proxy recommended if blocks persist)
# WOOLIESBOT_HTTP_PROXY=http://user:pass@host:port
# WOOLIESBOT_WOOLIES_PROXY=http://user:pass@host:port
#
# Coles discovery tuning
# WOOLIESBOT_COLES_DISCOVERY_SLEEP_SEC=2
# WOOLIESBOT_COLES_DISCOVERY_MIN_SCORE=0.06

# ── Variant discovery (scripts/discover_variants.py + weekly snippet) ─────────
# Never auto-writes docs/data.json. Review via docs/discovery-review.html .
# WOOLIESBOT_DISCOVERY_GROUP=pending_review       # compare_group stamped on drafts
# WOOLIESBOT_DISCOVERY_MAX_QUERIES=8
# WOOLIESBOT_DISCOVERY_SLEEP_SEC=3
# WOOLIESBOT_DISCOVERY_ONLY_TYPE=household        # optional filter for inventory-scan
# WOOLIESBOT_DISCOVERY_QUERY_LOG=logs/discovery-query.log

