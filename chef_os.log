on-v2__V445P\">\u003Cwc-product-tile>\u003C/wc-product-tile>\u003C/div>\u003C/div>\u003Cdiv class=\"horizontal-mode_component_card__0LpcI\" style=\"height: auto; width: 224px;\">\u003Cdiv class=\"product-tile_component_product-tile__rcGmj product-tile_component_layout-horizontal-collection-v2__V445P\">\u003Cwc-product-tile>\u003C/wc-product-tile>\u003C/div>\u003C/div>\u003Cdiv class=\"horizontal-mode_component_card__0LpcI\" style=\"height: auto; width: 224px;\">\u003Cdiv class=\"product-tile_component_product-tile__rcGmj product-tile_component_layout-horizontal-collection-v2__V445P\">\u003Cwc-product-tile>\u003C/wc-product-tile>\u003C/div>\u003C/div>\u003Cdiv class=\"horizontal-mode_component_card__0LpcI\" style=\"height: auto; width: 224px;\">\u003Cdiv class=\"product-tile_component_product-tile__rcGmj product-tile_component_layout-horizontal-collection-v2__V445P\">\u003Cwc-product-tile>\u003C/wc-product-tile>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003Cdiv class=\"aem-GridColumn aem-GridColumn--default--12\">\u003Cdiv class=\"container_component_container-next__wXs86\">\u003Cdiv id=\"container-23c01c5b4a\" data-testid=\"container-23c01c5b4a\">\u003Cdiv class=\"aem-GridColumn aem-GridColumn--default--12 aem-space-section-small-b\">\u003Cdiv class=\" aem-Grid aem-Grid--12 aem-Grid--default--12 aem-container\">\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003Cscript id=\"pdp-schema\" data-testid=\"pdp-schema\" type=\"application/ld+json\">{\"@type\":\"Product\",\"name\":\"Woolworths Natural Greek Style Yoghurt  1kg\",\"image\":\"https://cdn0.woolworths.media/content/wowproductimages/large/571487.jpg\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":4.56,\"ratingCount\":1231},\"brand\":{\"@type\":\"Organization\",\"name\":\"Woolworths\"},\"offers\":{\"@type\":\"Offer\",\"potentialAction\":{\"@type\":\"BuyAction\"},\"url\":\"https://www.woolworths.com.au/shop/productdetails/571487/woolworths-natural-greek-style-yoghurt\",\"availability\":\"http://schema.org/InStock\",\"price\":3.8,\"priceCurrency\":\"AUD\",\"priceSpecification\":{\"@type\":\"UnitPriceSpecification\",\"priceCurrency\":\"AUD\",\"priceType\":\"https://schema.org/ListPrice\",\"price\":0.38,\"unitText\":\"1kg\"},\"seller\":{\"@type\":\"Organization\",\"name\":\"Woolworths\"}},\"review\":[{\"@type\":\"Review\",\"description\":\"Value and quality. I was surprised how good this brand is. It is just thick enough, really creamy, and little bit tangy, and great in sweet and savoury dishes.\",\"author\":{\"@type\":\"Person\",\"name\":\"aupanda\"},\"datePublished\":\"2026-04-11T06:01:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":5,\"worstRating\":1}},{\"@type\":\"Review\",\"description\":\"Woolworths Natural Greek Style Yoghurt 1kg. Creamy and mildly tangy, this yoghurt works well for breakfast or cooking. The texture is fairly smooth, though not as thick as premium Greek yoghurts. Flavour is simple and slightly plain. Good value for the size, but don’t expect a rich, indulgent experience.\",\"author\":{\"@type\":\"Person\",\"name\":\"imsorryto\"},\"datePublished\":\"2026-04-04T08:02:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":3,\"worstRating\":1}},{\"@type\":\"Review\",\"description\":\"Decent Greek yogurt! I loved this sample, such a versatile product to use. We used with granola and even on tacos. I would buy again. 😊\",\"author\":{\"@type\":\"Person\",\"name\":\"mushishroom\"},\"datePublished\":\"2026-04-01T11:02:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":4,\"worstRating\":1}},{\"@type\":\"Review\",\"description\":\"Good value and quality. Good value and quality product and alternative to a branded product. Not much else to say though... it's yoghurt!\",\"author\":{\"@type\":\"Person\",\"name\":\"Jholt001\"},\"datePublished\":\"2026-03-30T02:00:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":5,\"worstRating\":1}},{\"@type\":\"Review\",\"description\":\"Great Value Yoghurt. This is my go to plain yoghurt for baking, marinade, dressings and sauces. Great price for the size. Not my favourite for snacking, but we do buy it regularly and I will buy again.\",\"author\":{\"@type\":\"Person\",\"name\":\"MissyChrissy\"},\"datePublished\":\"2026-03-25T19:06:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":4,\"worstRating\":1}},{\"@type\":\"Review\",\"description\":\"Good flavour. Smooth and creamy. Could be a bit thicker\",\"author\":{\"@type\":\"Person\",\"name\":\"simbas_mum\"},\"datePublished\":\"2026-03-25T02:58:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":4,\"worstRating\":1}},{\"@type\":\"Review\",\"description\":\"Perfect Consistency. We have been using this yoghurt for years. Mostly as a topping for on our cereal, but also to make dips. It is not not sloppy or watered down and has a balanced natural flavour.\",\"author\":{\"@type\":\"Person\",\"name\":\"haveamunch\"},\"datePublished\":\"2026-03-24T21:04:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":5,\"worstRating\":1}},{\"@type\":\"Review\",\"description\":\"Decent Yoghurt. Good value nice yoghurt, I’d buy again\",\"author\":{\"@type\":\"Person\",\"name\":\"curtisy\"},\"datePublished\":\"2026-03-24T20:30:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":4,\"worstRating\":1}},{\"@type\":\"Review\",\"description\":\"Tasty and affordable Greek style yoghurt. Creamy texture - good for oats, smoothies or cooking. It’s the Greek style.\",\"author\":{\"@type\":\"Person\",\"name\":\"rkng7\"},\"datePublished\":\"2026-03-24T19:12:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":5,\"worstRating\":1}},{\"@type\":\"Review\",\"description\":\"Very afforfable. Tastes like greek yoghurt, consistency like all the other yoghurts. Great for baking and cooking with. Prefer potset so hoping a potset ypghutt will come out in the range\",\"author\":{\"@type\":\"Person\",\"name\":\"leemclean\"},\"datePublished\":\"2026-03-18T20:46:00.0000000+00:00\",\"reviewRating\":{\"@type\":\"Rating\",\"bestRating\":5,\"ratingValue\":4,\"worstRating\":1}}],\"sku\":\"571487\",\"@context\":\"https://schema.org\",\"gtin\":\"9300633631536\"}\u003C/script>\u003C/div>\u003C/div>\u003Cdiv class=\"aem-GridColumn aem-GridColumn--default--12\">\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/div>\u003C/main>\u003Cscript id=\"content-xfcf-pagenames\" type=\"application/json\">[\"/shop\",\"/shop/productdetails\",\"/shop/productdetails/571487\",\"pdp-accordion\",\"pdp-similar-items\",\"tobacco-banner\",\"pdp-product-details-panel\",\"pdp-people-who-bought-this-item-also-bought\",\"pdp-coupon-banner\",\"pdp-country-of-origin-label\",\"pdp-you-may-also-like\"]\u003C/script>\u003C/div>\u003Cscript id=\"__NEXT_DATA__\" type=\"application/json\">{\"props\":{\"pageProps\":{\"model\":{\"resourcePath\":\"/content/woolworths/shop/productdetails/default/jcr:content/root\",\"lazyLoad\":\"\",\"id\":\"container-4b3ed9cce9\",\"columnClassNames\":{\"container\":\"aem-GridColumn aem-GridColumn--default--12\",\"analytics\":\"aem-GridColumn aem-GridColumn--default--12\"},\"gridClassNames\":\"aem-Grid aem-Grid--12 aem-Grid--default--12\",\"columnCount\":12,\"isInEditor\":\"\",\"layout\":\"RESPONSIVE_GRID\",\"appliedCssClassNames\":\"aem-space-section-medium-t aem-space-section-medium-b\",\"cqItems\":{\"container\":{\"resourcePath\":\"/conf/woolworths-shared/settings/wcm/templates/product-details-web-page-template/structure/jcr:content/root/container\",\"lazyLoad\":false,\"id\":\"container-e708d64b90\",\"columnClassNames\":{\"container\":\"aem-GridColumn aem-GridColumn--default-